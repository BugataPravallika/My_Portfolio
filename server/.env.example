# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Allowed frontend origins (comma separated)
CLIENT_URL=http://localhost:5173,https://your-frontend.vercel.app

# Nodemailer configuration (Optional - fallback is simulated log display)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
RECEIVER_EMAIL=your-recipient-email@gmail.com
